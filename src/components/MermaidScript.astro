---
// MermaidScript.astro - 加载 Mermaid.js 并使用 retro/Win95 主题初始化
// 仅在页面包含 .mermaid 元素时生效
---
<script is:inline>
  (function() {
    if (!document.querySelector('.mermaid')) return;
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js';
    s.onload = function() {
      mermaid.initialize({
        startOnLoad: true,
        theme: 'base',
        securityLevel: 'loose',
        themeVariables: {
          primaryColor: '#c0c0c0',
          primaryTextColor: '#000000',
          primaryBorderColor: '#000000',
          lineColor: '#404040',
          secondaryColor: '#dcdcdc',
          tertiaryColor: '#e8e8e8',
          background: '#e0e0e0',
          mainBkg: '#c0c0c0',
          secondBkg: '#dcdcdc',
          fontFamily: 'ui-monospace, "Geist Mono", monospace',
          fontSize: '15px',
          clusterBkg: '#e8e8e8',
          clusterBorder: '#606060',
          edgeLabelBackground: '#c0c0c0',
          nodeBorder: '#000000',
          actorBkg: '#c0c0c0',
          actorBorder: '#000000',
          actorTextColor: '#000000',
          signalColor: '#404040',
          signalTextColor: '#000000',
          labelBoxBkgColor: '#c0c0c0',
          labelBoxBorderColor: '#000000',
          labelTextColor: '#000000',
          loopTextColor: '#000000',
          noteBkgColor: '#fffacd',
          noteBorderColor: '#000000',
          noteTextColor: '#000000',
          activationBkgColor: '#d0d0d0',
          activationBorderColor: '#000000',
          sequenceNumberColor: '#ffffff'
        },
        flowchart: {
          useMaxWidth: false,
          htmlLabels: true,
          curve: 'basis',
          nodeSpacing: 50,
          rankSpacing: 50,
          padding: 15
        },
        sequence: {
          useMaxWidth: true,
          wrap: true,
          actorMargin: 60,
          boxMargin: 12,
          noteMargin: 10,
          messageMargin: 40,
          mirrorActor: false,
          bottomMarginAdj: 8
        }
      });
    };
    document.head.appendChild(s);
  })();
</script>
