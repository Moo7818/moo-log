---
export interface Node {
  x: number;
  y: number;
  w?: number;
  h?: number;
  label: string;
  kind?: 'rect' | 'diamond' | 'terminal';
  color?: string;
  textColor?: string;
  dashed?: boolean;
}

export interface Edge {
  from: [number, number];
  to: [number, number];
  label?: string;
  dashed?: boolean;
  color?: string;
}

export interface Props {
  title?: string;
  nodes: Node[];
  edges: Edge[];
  width?: number;
  height?: number;
}

const { title, nodes, edges, width = 640, height = 360 } = Astro.props;

const arrowId = 'arrow-' + Math.random().toString(36).slice(2, 6);
const arrowDashedId = 'arrow-dashed-' + Math.random().toString(36).slice(2, 6);
---

<figure class="svg-wrapper" style="display:flex;justify-content:center;padding:20px;background:var(--background);border:2px solid var(--border);box-shadow:inset 2px 2px 0px 0px rgba(0,0,0,0.1);">
  <svg viewBox={`0 0 ${width} ${height}`} xmlns="http://www.w3.org/2000/svg" style="font-family:'Geist Mono',monospace;max-width:100%;height:auto;">
    <defs>
      <pattern id="scanlines-fc" patternUnits="userSpaceOnUse" width="4" height="4">
        <line x1="0" y1="0" x2="4" y2="0" stroke="rgba(0,0,0,0.04)" stroke-width="1"/>
      </pattern>
      <marker id={arrowId} viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto">
        <path d="M0,0 L10,5 L0,10" fill="var(--foreground, #111)"/>
      </marker>
      <marker id={arrowDashedId} viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto">
        <path d="M0,0 L10,5 L0,10" fill="var(--accent, #0040ff)"/>
      </marker>
    </defs>
    <rect width={width} height={height} fill="url(#scanlines-fc)"/>

    {title && (
      <text x={width / 2} y="30" text-anchor="middle" font-size="13" font-weight="600" fill="var(--muted-foreground, #999)">{title}</text>
    )}

    <!-- Edges -->
    {edges.map(e => {
      const marker = e.dashed ? `url(#${arrowDashedId})` : `url(#${arrowId})`;
      const color = e.color || (e.dashed ? 'var(--accent, #0040ff)' : 'var(--foreground, #111)');
      return (
        <line x1={e.from[0]} y1={e.from[1]} x2={e.to[0]} y2={e.to[1]}
          stroke={color} stroke-width="2"
          stroke-dasharray={e.dashed ? "4,3" : "none"}
          marker-end={marker} />
      );
    })}

    <!-- Edge labels -->
    {edges.filter(e => e.label).map(e => {
      const mx = (e.from[0] + e.to[0]) / 2;
      const my = (e.from[1] + e.to[1]) / 2;
      const color = e.dashed ? 'var(--accent, #0040ff)' : 'var(--muted-foreground, #999)';
      return (
        <text x={mx} y={my - 8} text-anchor="middle" font-size="10" fill={color}>{e.label}</text>
      );
    })}

    <!-- Nodes -->
    {nodes.map(n => {
      const w = n.w || 140;
      const h = n.h || 44;
      const cx = n.x + w / 2;
      const cy = n.y + h / 2;
      const strokeColor = n.color || (n.dashed ? 'var(--accent, #0040ff)' : 'var(--foreground, #111)');
      const fillColor = n.kind === 'terminal' ? 'var(--primary, #111)' : 'var(--card, #f0f0f0)';
      const textFill = n.kind === 'terminal' ? 'var(--primary-foreground, #fff)' : (n.textColor || 'var(--foreground, #111)');

      if (n.kind === 'diamond') {
        // Diamond node
        return (
          <polygon
            points={`${cx},${n.y} ${n.x + w},${cy} ${cx},${n.y + h} ${n.x},${cy}`}
            fill={fillColor} stroke={strokeColor} stroke-width="2" />
        );
      }

      return (
        <rect x={n.x} y={n.y} width={w} height={h} rx="0"
          fill={fillColor} stroke={strokeColor} stroke-width="2"
          stroke-dasharray={n.dashed ? "4,2" : "none"} />
      );
    })}

    <!-- Node labels -->
    {nodes.map(n => {
      const w = n.w || 140;
      const h = n.h || 44;
      const cx = n.x + w / 2;
      const cy = n.y + h / 2;
      const textFill = n.kind === 'terminal' ? 'var(--primary-foreground, #fff)' : (n.textColor || 'var(--foreground, #111)');
      return (
        <text x={cx} y={cy + 4} text-anchor="middle" font-size="12" fill={textFill}>{n.label}</text>
      );
    })}
  </svg>
</figure>